# Copy to .env.local and fill in real values.

# Base URL of the h2-flow backend (REST + SSE).
VITE_API_BASE_URL=https://your-backend.example.com/api/v1

# Mercure hub endpoint (paid users realtime).
VITE_MERCURE_HUB_URL=https://your-backend.example.com/.well-known/mercure

# RequestSigner: HMAC shared secret embedded in the bundle.
# In production this is rotated by the backend; locally any non-empty string is fine.
VITE_EXT_SECRET=dev-extension-secret-change-me

# Stable extension identity. The backend uses this to whitelist installs.
VITE_EXT_ID=h2flow-dev

# Mock backend toggle. Default: ON (mock returns canned data for every Phase
# 1 endpoint — see docs/MOCK-API.md). Set to "false" when you have a real
# backend wired up to VITE_API_BASE_URL.
VITE_USE_MOCK=true
